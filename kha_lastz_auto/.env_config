  CollectZGoldFull: 0 * * * *
  CollectExplorationReward: 0 */2 * * *
  SoliderTrain: 0 */3 * * *
  HelpAlliance: '*/2 * * * *'
  CheckMail: 0 */5 * * *
  DonateAllianceTech: '*/60 * * * *'
fn_enabled:
  PinLoggin: true
  BeingAttacked: true
  TestAllianceAttack: true
  TurnOnShield: false
  FightBoomer: false
  ClickTreasure: true
